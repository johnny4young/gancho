#!/bin/sh
# Opt-in pre-push gate: runs the CI checks before code leaves the machine
# (lint always, plus the package unit tests — the no-content-logging and
# localization gates live there). Installed via `make hooks` (sets
# core.hooksPath to this directory).
#
# Both `make lint` and `make test` need a Swift toolchain, so on a box
# without one (Linux contributors, doc-only environments) the hook skips
# with a note instead of blocking the push — CI enforces the same gates.
set -e

cd "$(git rev-parse --show-toplevel)"

if ! command -v swift >/dev/null 2>&1; then
    echo "pre-push: no Swift toolchain found — skipping lint+tests (CI still enforces them)."
    exit 0
fi

echo "pre-push: make lint"
if ! make lint; then
    echo ""
    echo "pre-push: lint failed — run 'make format' and re-commit." >&2
    exit 1
fi

echo "pre-push: make test"
if ! make test; then
    echo ""
    echo "pre-push: tests failed — fix before pushing (or bypass once with 'git push --no-verify')." >&2
    exit 1
fi
