            "state": "translated",
            "value": "enlace"
          }
        }
      }
    },
    "uuid": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "UUID"
          }
        }
      }
    },
    "Intelligence features": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Funciones de inteligencia"
          }
        }
      }
    },
    "Sensitive data": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Datos sensibles"
          }
        }
      }
    },
    "Always on": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siempre activa"
          }
        }
      }
    },
    "Smart classification": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clasificación inteligente"
          }
        }
      }
    },
    "A deterministic classifier tags each clip in under 5 ms — JWT, JSON, color, card, URL… — with zero network. Drives previews, Smart Actions, and masking.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un clasificador determinista etiqueta cada clip en menos de 5 ms — JWT, JSON, color, tarjeta, URL… — sin red. Alimenta los previews, las Smart Actions y el enmascarado."
          }
        }
      }
    },
    "Smarter titles": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Títulos más inteligentes"
          }
        }
      }
    },
    "Apple Intelligence writes a short, specific title on-device, falling back to heuristics on any failure — and never puts a secret in a title.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence escribe un título corto y específico en el dispositivo, con respaldo en heurísticas ante cualquier fallo — y nunca pone un secreto en un título."
          }
        }
      }
    },
    "Semantic search": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Búsqueda semántica"
          }
        }
      }
    },
    "Find a clip by meaning, not just exact words. A 512-dim embedding indexes history on-device; the model assets stay local.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Encuentra un clip por significado, no solo por palabras exactas. Un embedding de 512 dimensiones indexa el historial en el dispositivo; los assets del modelo quedan locales."
          }
        }
      }
    },
    "Searchable screenshots": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Capturas buscables"
          }
        }
      }
    },
    "On-device OCR reads text out of image clips and adds it to the full-text index, so a screenshot is findable by the words inside it.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El OCR en el dispositivo lee el texto de los clips de imagen y lo agrega al índice de texto completo, así una captura se encuentra por las palabras que tiene dentro."
          }
        }
      }
    },
    "Rewrite a clip before pasting — summarize, fix grammar, change tone, pull key points, or redact PII. Model-backed rewrites use Apple Intelligence on-device; deterministic redaction needs no model.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reescribe un clip antes de pegarlo — resume, corrige gramática, cambia el tono, saca puntos clave o redacta PII. Las reescrituras con modelo usan Apple Intelligence en el dispositivo; la redacción determinista no necesita modelo."
          }
        }
      }
    },
    "Detect & mask secrets": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detectar y enmascarar secretos"
          }
        }
      }
    },
    "If you copy a key by accident, gancho masks the preview (●●●● + last 4) and auto-expires it after 10 minutes. Deterministic, on-device.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si copias una llave por accidente, gancho enmascara el preview (●●●● + últimos 4) y la expira sola a los 10 minutos. Determinista, en el dispositivo."
          }
        }
      }
    },
    "Capture": {
      "extractionState": "stale",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura"
          }
        }
