    "Gancho Pro": {
      "extractionState": "stale",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gancho Pro"
          }
        }
      }
    },
    "Gancho sends no clipboard content anywhere. Verify it yourself with Little Snitch or any network monitor — this screen included.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gancho no envía contenido del portapapeles a ninguna parte. Verifícalo tú mismo con Little Snitch o cualquier monitor de red — esta pantalla incluida."
          }
        }
      }
    },
    "Gancho still works in manual mode: your history stays searchable and you can capture via the share sheet on iPhone. To re-enable automatic capture, allow Gancho in System Settings and relaunch.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gancho sigue funcionando en modo manual: tu historial sigue siendo buscable y puedes capturar con el share sheet en iPhone. Para reactivar la captura automática, permite Gancho en Configuración del Sistema y relanza."
          }
        }
      }
    },
    "Gancho will retry automatically.": {
      "extractionState": "stale",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gancho lo reintentará automáticamente."
