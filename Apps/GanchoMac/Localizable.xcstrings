      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fijado"
          }
        }
      }
    },
    "Press the shortcut, pick a clip with ↑↓, hit Enter — it pastes right where you were typing. That's the whole loop.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presiona el atajo, elige un clip con ↑↓ y dale Enter — se pega justo donde estabas escribiendo. Ese es todo el ciclo."
          }
        }
      }
    },
    "Pretty-print JSON": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Formatear JSON"
