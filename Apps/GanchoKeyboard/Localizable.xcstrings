        }
      }
    },
    "Turn on Full Access in Settings → General → Keyboard → Keyboards → Gancho. Nothing you copy or type ever leaves your device.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa Acceso Completo en Ajustes → General → Teclado → Teclados → Gancho. Nada de lo que copies o escribas sale de tu dispositivo."
          }
        }
      }
    }
  },
  "version": "1.0"
