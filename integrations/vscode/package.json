{
  "name": "gancho-save",
  "displayName": "Gancho: Save Selection",
  "description": "Save the current selection to your Gancho clipboard Library as a snippet — local, offline, no account.",
  "version": "0.1.0",
  "publisher": "johnny4young",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gancho.saveSelection",
        "title": "Gancho: Save Selection"
      }
    ],
    "configuration": {
      "title": "Gancho",
      "properties": {
        "gancho.path": {
          "type": "string",
          "default": "gancho",
          "description": "Path to the gancho CLI. Defaults to 'gancho' on your PATH (installed via Homebrew)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
